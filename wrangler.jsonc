{
  "name": "michi",
  "compatibility_date": "2026-07-01",
  "main": "worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "durable_objects": {
    "bindings": [
      { "name": "EXPORT_TALLY", "class_name": "ExportTally" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ExportTally"] }
  ]
}
